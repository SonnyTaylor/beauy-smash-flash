{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "productName": "Beauy Smash Flash",
  "version": "1.0.0",
  "identifier": "com.beauy.smashflash",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Beauy Smash Flash",
        "width": 1280,
        "height": 720,
        "resizable": true,
        "maximized": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
